{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["llm", "serverless", "serverless-gpu"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1,
        "regex": "/VictoriaMetrics/"
      },
      {
        "name": "app_id",
        "label": "Endpoint",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(serverless_http_requests_total, app_id)",
        "query": { "query": "label_values(serverless_http_requests_total, app_id)", "refId": "StandardVariableQuery" },
        "includeAll": false,
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "current": {}
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(serverless_ttft_seconds_count{app_id=~\"$app_id\"}, model)",
        "query": { "query": "label_values(serverless_ttft_seconds_count{app_id=~\"$app_id\"}, model)", "refId": "StandardVariableQuery" },
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Serverless Fleet — requests / latency / TTFT / TPS",
  "uid": "serverless-fleet-overview",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests (range)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "round(sum(increase(serverless_http_requests_total{app_id=~\"$app_id\"}[$__range])))", "instant": true }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "2xx",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "round(sum(increase(serverless_http_requests_total{app_id=~\"$app_id\", http_status=~\"2..\"}[$__range])))", "instant": true }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Errors (non-2xx)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "round(sum(increase(serverless_http_requests_total{app_id=~\"$app_id\", http_status!~\"2..\"}[$__range])))", "instant": true }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error rate",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 } ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "100 * sum(increase(serverless_http_requests_total{app_id=~\"$app_id\", http_status!~\"2..\"}[$__range])) / clamp_min(sum(increase(serverless_http_requests_total{app_id=~\"$app_id\"}[$__range])), 1)", "instant": true }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Avg TTFT",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3, "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(increase(serverless_ttft_seconds_sum{app_id=~\"$app_id\", model=~\"$model\"}[$__range])) / clamp_min(sum(increase(serverless_ttft_seconds_count{app_id=~\"$app_id\", model=~\"$model\"}[$__range])), 1)", "instant": true }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Avg TPS (tok/s)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(increase(serverless_tokens_per_second_sum{app_id=~\"$app_id\", model=~\"$model\"}[$__range])) / clamp_min(sum(increase(serverless_tokens_per_second_count{app_id=~\"$app_id\", model=~\"$model\"}[$__range])), 1)", "instant": true }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Request rate by HTTP status",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal", "group": "A" }, "lineWidth": 1 } }, "overrides": [] },
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (http_status) (rate(serverless_http_requests_total{app_id=~\"$app_id\"}[$__rate_interval]))", "legendFormat": "{{http_status}}" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Request rate by route",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal", "group": "A" }, "lineWidth": 1 } }, "overrides": [] },
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (route) (rate(serverless_http_requests_total{app_id=~\"$app_id\"}[$__rate_interval]))", "legendFormat": "{{route}}" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Job outcomes rate",
      "description": "Terminal inference-job outcomes (async /run jobs that 200 at enqueue but later fail/timeout don't show as 5xx in the HTTP counters).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal", "group": "A" }, "lineWidth": 1 } }, "overrides": [] },
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (status) (rate(serverless_jobs_total{app_id=~\"$app_id\"}[$__rate_interval]))", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "HTTP latency (percentiles)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(serverless_http_request_duration_seconds_bucket{app_id=~\"$app_id\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.90, sum by (le) (rate(serverless_http_request_duration_seconds_bucket{app_id=~\"$app_id\"}[$__rate_interval])))", "legendFormat": "p90" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(serverless_http_request_duration_seconds_bucket{app_id=~\"$app_id\"}[$__rate_interval])))", "legendFormat": "p99" },
        { "refId": "D", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(serverless_http_request_duration_seconds_sum{app_id=~\"$app_id\"}[$__rate_interval])) / sum(rate(serverless_http_request_duration_seconds_count{app_id=~\"$app_id\"}[$__rate_interval]))", "legendFormat": "avg" }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Time-to-first-token (percentiles)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(serverless_ttft_seconds_bucket{app_id=~\"$app_id\", model=~\"$model\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.90, sum by (le) (rate(serverless_ttft_seconds_bucket{app_id=~\"$app_id\", model=~\"$model\"}[$__rate_interval])))", "legendFormat": "p90" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(serverless_ttft_seconds_bucket{app_id=~\"$app_id\", model=~\"$model\"}[$__rate_interval])))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Output throughput TPS (percentiles, higher is better)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "calcs": ["mean", "min"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(serverless_tokens_per_second_bucket{app_id=~\"$app_id\", model=~\"$model\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.10, sum by (le) (rate(serverless_tokens_per_second_bucket{app_id=~\"$app_id\", model=~\"$model\"}[$__rate_interval])))", "legendFormat": "p10 (slowest)" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.90, sum by (le) (rate(serverless_tokens_per_second_bucket{app_id=~\"$app_id\", model=~\"$model\"}[$__rate_interval])))", "legendFormat": "p90 (fastest)" }
      ]
    },
    {
      "id": 13,
      "type": "heatmap",
      "title": "HTTP latency heatmap",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "options": { "calculate": false, "cellGap": 1, "color": { "scheme": "Spectral", "mode": "scheme", "steps": 64 }, "yAxis": { "unit": "s", "axisPlacement": "left" }, "tooltip": { "show": true, "yHistogram": true }, "legend": { "show": true } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (le) (increase(serverless_http_request_duration_seconds_bucket{app_id=~\"$app_id\"}[$__rate_interval]))", "format": "heatmap", "legendFormat": "{{le}}" }
      ]
    },
    {
      "id": 14,
      "type": "heatmap",
      "title": "TTFT heatmap",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "options": { "calculate": false, "cellGap": 1, "color": { "scheme": "Greens", "mode": "scheme", "steps": 64 }, "yAxis": { "unit": "s", "axisPlacement": "left" }, "tooltip": { "show": true, "yHistogram": true }, "legend": { "show": true } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (le) (increase(serverless_ttft_seconds_bucket{app_id=~\"$app_id\", model=~\"$model\"}[$__rate_interval]))", "format": "heatmap", "legendFormat": "{{le}}" }
      ]
    },
    {
      "id": 15,
      "type": "heatmap",
      "title": "TPS heatmap (tok/s)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "options": { "calculate": false, "cellGap": 1, "color": { "scheme": "Purples", "mode": "scheme", "steps": 64 }, "yAxis": { "unit": "short", "axisPlacement": "left" }, "tooltip": { "show": true, "yHistogram": true }, "legend": { "show": true } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (le) (increase(serverless_tokens_per_second_bucket{app_id=~\"$app_id\", model=~\"$model\"}[$__rate_interval]))", "format": "heatmap", "legendFormat": "{{le}}" }
      ]
    },
    {
      "id": 16,
      "type": "table",
      "title": "Requests by route & status (range)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "filterable": true }, "unit": "short" }, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "requests", "desc": true } ] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (method, route, http_status) (round(increase(serverless_http_requests_total{app_id=~\"$app_id\"}[$__range])))", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "requests" } } }
      ]
    },
    {
      "id": 17,
      "type": "table",
      "title": "TTFT / TPS by model (range avg)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "filterable": true } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "avg TTFT" }, "properties": [ { "id": "unit", "value": "s" }, { "id": "decimals", "value": 3 } ] },
          { "matcher": { "id": "byName", "options": "avg TPS" }, "properties": [ { "id": "unit", "value": "short" }, { "id": "decimals", "value": 1 } ] }
        ]
      },
      "options": { "showHeader": true },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (model) (increase(serverless_ttft_seconds_sum{app_id=~\"$app_id\", model=~\"$model\"}[$__range])) / clamp_min(sum by (model) (increase(serverless_ttft_seconds_count{app_id=~\"$app_id\", model=~\"$model\"}[$__range])), 1)", "instant": true, "format": "table" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (model) (increase(serverless_tokens_per_second_sum{app_id=~\"$app_id\", model=~\"$model\"}[$__range])) / clamp_min(sum by (model) (increase(serverless_tokens_per_second_count{app_id=~\"$app_id\", model=~\"$model\"}[$__range])), 1)", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value #A": "avg TTFT", "Value #B": "avg TPS" } } }
      ]
    }
  ]
}
