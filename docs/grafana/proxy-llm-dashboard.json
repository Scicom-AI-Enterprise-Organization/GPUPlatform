{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["llm", "proxy", "serverless-gpu"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1,
        "regex": "/VictoriaMetrics/"
      },
      {
        "name": "proxy",
        "label": "Proxy",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(proxy_requests_total, proxy)",
        "query": { "query": "label_values(proxy_requests_total, proxy)", "refId": "StandardVariableQuery" },
        "includeAll": false,
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "current": {}
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(proxy_requests_total{proxy=~\"$proxy\"}, model)",
        "query": { "query": "label_values(proxy_requests_total{proxy=~\"$proxy\"}, model)", "refId": "StandardVariableQuery" },
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "LLM Proxy — requests / latency / TTFT / TPS",
  "uid": "llm-proxy-overview",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests (range)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "round(sum(increase(proxy_requests_total{proxy=~\"$proxy\", model=~\"$model\"}[$__range])))", "instant": true }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Completed",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "round(sum(increase(proxy_requests_total{proxy=~\"$proxy\", model=~\"$model\", status=\"completed\"}[$__range])))", "instant": true }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Errors",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "round(sum(increase(proxy_requests_total{proxy=~\"$proxy\", model=~\"$model\", status!~\"completed|cancelled\"}[$__range])))", "instant": true }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error rate",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 } ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "100 * sum(increase(proxy_requests_total{proxy=~\"$proxy\", model=~\"$model\", status!~\"completed|cancelled\"}[$__range])) / clamp_min(sum(increase(proxy_requests_total{proxy=~\"$proxy\", model=~\"$model\"}[$__range])), 1)", "instant": true }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Avg TTFT",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3, "color": { "mode": "fixed", "fixedColor": "green" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(increase(proxy_ttft_seconds_sum{proxy=~\"$proxy\", model=~\"$model\"}[$__range])) / clamp_min(sum(increase(proxy_ttft_seconds_count{proxy=~\"$proxy\", model=~\"$model\"}[$__range])), 1)", "instant": true }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Avg TPS (tok/s)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(increase(proxy_tokens_per_second_sum{proxy=~\"$proxy\", model=~\"$model\"}[$__range])) / clamp_min(sum(increase(proxy_tokens_per_second_count{proxy=~\"$proxy\", model=~\"$model\"}[$__range])), 1)", "instant": true }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Request rate by outcome",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal", "group": "A" }, "lineWidth": 1 } }, "overrides": [] },
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (status) (rate(proxy_requests_total{proxy=~\"$proxy\", model=~\"$model\"}[$__rate_interval]))", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Request rate by upstream",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal", "group": "A" }, "lineWidth": 1 } }, "overrides": [] },
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (upstream) (rate(proxy_requests_total{proxy=~\"$proxy\", model=~\"$model\"}[$__rate_interval]))", "legendFormat": "{{upstream}}" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "End-to-end latency (percentiles)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(proxy_request_duration_seconds_bucket{proxy=~\"$proxy\", model=~\"$model\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.90, sum by (le) (rate(proxy_request_duration_seconds_bucket{proxy=~\"$proxy\", model=~\"$model\"}[$__rate_interval])))", "legendFormat": "p90" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(proxy_request_duration_seconds_bucket{proxy=~\"$proxy\", model=~\"$model\"}[$__rate_interval])))", "legendFormat": "p99" },
        { "refId": "D", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(proxy_request_duration_seconds_sum{proxy=~\"$proxy\", model=~\"$model\"}[$__rate_interval])) / sum(rate(proxy_request_duration_seconds_count{proxy=~\"$proxy\", model=~\"$model\"}[$__rate_interval]))", "legendFormat": "avg" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Time-to-first-token (percentiles)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(proxy_ttft_seconds_bucket{proxy=~\"$proxy\", model=~\"$model\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.90, sum by (le) (rate(proxy_ttft_seconds_bucket{proxy=~\"$proxy\", model=~\"$model\"}[$__rate_interval])))", "legendFormat": "p90" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(proxy_ttft_seconds_bucket{proxy=~\"$proxy\", model=~\"$model\"}[$__rate_interval])))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Output throughput TPS (percentiles, higher is better)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "calcs": ["mean", "min"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(proxy_tokens_per_second_bucket{proxy=~\"$proxy\", model=~\"$model\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.10, sum by (le) (rate(proxy_tokens_per_second_bucket{proxy=~\"$proxy\", model=~\"$model\"}[$__rate_interval])))", "legendFormat": "p10 (slowest)" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.90, sum by (le) (rate(proxy_tokens_per_second_bucket{proxy=~\"$proxy\", model=~\"$model\"}[$__rate_interval])))", "legendFormat": "p90 (fastest)" }
      ]
    },
    {
      "id": 12,
      "type": "heatmap",
      "title": "Latency heatmap",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "options": { "calculate": false, "cellGap": 1, "color": { "scheme": "Spectral", "mode": "scheme", "steps": 64 }, "yAxis": { "unit": "s", "axisPlacement": "left" }, "tooltip": { "show": true, "yHistogram": true }, "legend": { "show": true } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (le) (increase(proxy_request_duration_seconds_bucket{proxy=~\"$proxy\", model=~\"$model\"}[$__rate_interval]))", "format": "heatmap", "legendFormat": "{{le}}" }
      ]
    },
    {
      "id": 13,
      "type": "heatmap",
      "title": "TTFT heatmap",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "options": { "calculate": false, "cellGap": 1, "color": { "scheme": "Greens", "mode": "scheme", "steps": 64 }, "yAxis": { "unit": "s", "axisPlacement": "left" }, "tooltip": { "show": true, "yHistogram": true }, "legend": { "show": true } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (le) (increase(proxy_ttft_seconds_bucket{proxy=~\"$proxy\", model=~\"$model\"}[$__rate_interval]))", "format": "heatmap", "legendFormat": "{{le}}" }
      ]
    },
    {
      "id": 14,
      "type": "heatmap",
      "title": "TPS heatmap (tok/s)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "options": { "calculate": false, "cellGap": 1, "color": { "scheme": "Purples", "mode": "scheme", "steps": 64 }, "yAxis": { "unit": "short", "axisPlacement": "left" }, "tooltip": { "show": true, "yHistogram": true }, "legend": { "show": true } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (le) (increase(proxy_tokens_per_second_bucket{proxy=~\"$proxy\", model=~\"$model\"}[$__rate_interval]))", "format": "heatmap", "legendFormat": "{{le}}" }
      ]
    },
    {
      "id": 15,
      "type": "table",
      "title": "Requests by upstream (range)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "filterable": true }, "unit": "short" }, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "requests", "desc": true } ] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (upstream, status) (round(increase(proxy_requests_total{proxy=~\"$proxy\", model=~\"$model\"}[$__range])))", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "requests" } } }
      ]
    },
    {
      "id": 16,
      "type": "table",
      "title": "Requests by model & outcome (range)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "filterable": true }, "unit": "short" }, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "requests", "desc": true } ] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (model, status) (round(increase(proxy_requests_total{proxy=~\"$proxy\", model=~\"$model\"}[$__range])))", "instant": true, "format": "table" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "requests" } } }
      ]
    },
    {
      "id": 17,
      "type": "state-timeline",
      "title": "SLO uptime — p99 TTFT ≤ 1.2s · p10 TPS ≥ 20 tok/s",
      "description": "Per-window SLO status — continuous, no gaps. Green = SLO met. Red = violated OR no data in that window (no traffic / API down). Missing evaluations are filled to 0 (red) via `or vector(0)`.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 44 },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 85, "lineWidth": 0 },
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "down / violated", "color": "red", "index": 0 }, "1": { "text": "OK", "color": "green", "index": 1 } } }
          ],
          "noValue": "no data"
        },
        "overrides": []
      },
      "options": { "mergeValues": true, "showValue": "never", "alignValue": "center", "rowHeight": 0.9, "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "(histogram_quantile(0.99, sum by (le) (rate(proxy_ttft_seconds_bucket{proxy=~\"$proxy\", model=~\"$model\"}[$__rate_interval]))) < bool 1.2) or vector(0)", "legendFormat": "p99 TTFT ≤ 1.2s" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "(histogram_quantile(0.10, sum by (le) (rate(proxy_tokens_per_second_bucket{proxy=~\"$proxy\", model=~\"$model\"}[$__rate_interval]))) > bool 20) or vector(0)", "legendFormat": "p10 TPS ≥ 20 tok/s" }
      ]
    }
  ]
}
