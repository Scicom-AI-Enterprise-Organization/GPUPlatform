# Gateway local dev env. Copy to gateway/.env and tweak.
# Loaded by `gateway` entrypoint via load_dotenv() at process start.

# Postgres + Redis come from docker compose (see repo-root docker-compose.yml).
# Bring them up with: docker compose up -d postgres redis
DATABASE_URL=postgresql+asyncpg://serverlessgpu:devpassword@localhost:5432/serverlessgpu
REDIS_URL=redis://localhost:6379

GATEWAY_BIND=127.0.0.1:8080
LOG_LEVEL=INFO
# Local dev: set to 1 to auto-restart the gateway on edits under
# gateway/gateway/. Leave 0/unset in prod (single stable process).
GATEWAY_RELOAD=0

# Skip session auth — every request acts as the seeded admin user.
# Requires ADMIN_USERNAME + ADMIN_PASSWORD below so the seed runs on boot.
AUTH_DISABLED=1
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@email.com
ADMIN_PASSWORD=admin

# Fernet key for encrypting provider secrets at rest (SSH private keys, API
# tokens). Required to create GPU Providers. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Changing this makes already-stored provider secrets undecryptable.
PROVIDER_SECRET_KEY=

# Provider off for local dev — no real GPU spawning.
AUTOSCALER=0
PROVIDER=fake

# Metrics off locally (build_metrics_env returns {} when these are empty).
METRICS_REMOTE_WRITE_URL=
METRICS_USERNAME=
METRICS_PASSWORD=

# Only needed if you flip PROVIDER=primeintellect or =runpod for real spawning.
# PI_API_KEY=
# PI_CUSTOM_TEMPLATE_ID=
# GATEWAY_PUBLIC_URL=
# RUNPOD_API_KEY=
# RUNPOD_TEMPLATE_ID=

# Reverse-tunnel mode for VM (bare-metal) serverless workers. When 1, the gateway
# forwards its own gateway port + Redis back over the SSH connection it opens to
# the VM, so a remote VM reaches them at its own localhost — no public gateway /
# Redis needed. Use for local dev or a single-gateway deploy. NOT for multi-replica
# HA (replicas would collide binding the VM's reverse port — expose WORKER_REDIS_URL
# instead). Default off.
# VM_REVERSE_TUNNEL=1
