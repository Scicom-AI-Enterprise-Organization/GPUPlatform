# Gateway API base URL — points at the serverless-gpu FastAPI gateway
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080
# Optional API key. Sent as Authorization: Bearer <key>. Leave empty for
# local dev — the gateway only enforces auth when GATEWAY_API_KEYS is set.
GATEWAY_API_KEY=
# Set to 1 to disable self-registration: hides the "Create one" link on /login,
# redirects /register -> /login, and 403s the /api/auth/register proxy. Empty =
# registration enabled. (Gateway /auth/register stays open to direct API calls.)
REGISTRATION_DISABLED=

# Turn off product surfaces in the web (comma-separated: inference,benchmark,compute).
# Hides the nav item AND redirects/blocks the section's pages. Mirrors the gateway's
# DISABLED_SECTIONS — set it on both sides for defense in depth. e.g. =compute
DISABLED_SECTIONS=
